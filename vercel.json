{
  "rewrites": [
    {
      "source": "/legacy-studio",
      "destination": "/design.html"
    },
    {
      "source": "/studio",
      "destination": "/index.html"
    },
    {
      "source": "/studio/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/checkout/payplus/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/checkout/:path*",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "bluetooth=(), camera=(), geolocation=(), hid=(), microphone=(), midi=(), payment=(), serial=(), usb=()"
        }
      ]
    }
  ],
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  }
}
