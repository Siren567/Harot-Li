generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  NEW
  PAID
  FULFILLED
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum InventoryReason {
  ORDER_PLACED
  ORDER_CANCELLED
  ORDER_REFUNDED
  MANUAL_ADJUSTMENT
  INITIAL_STOCK
  RESTOCK
  CORRECTION
}

enum AdminRole {
  OWNER
  ADMIN
  STAFF
}

model Customer {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  redemptions  CouponRedemption[]
}

model Order {
  id             String   @id @default(uuid())
  orderNumber    String   @unique
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  subtotal       Int
  shippingFee    Int
  discountAmount Int
  total          Int

  couponId       String?
  coupon         Coupon?  @relation(fields: [couponId], references: [id], onDelete: SetNull)

  status         OrderStatus @default(NEW)
  items          Json
  legacyItems    Json?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  redemptions    CouponRedemption[]
  orderItems     OrderItem[]

  @@index([customerId])
  @@index([couponId])
  @@index([status])
  @@index([createdAt])
}

model Coupon {
  id                     String   @id @default(uuid())
  code                   String   @unique
  name                   String
  description            String?

  discountType           CouponDiscountType
  discountValue          Int

  isActive               Boolean  @default(true)
  startsAt               DateTime?
  endsAt                 DateTime?
  hasNoExpiry            Boolean  @default(false)

  minCartAmount          Int?
  maxCartAmount          Int?
  minItemsQuantity       Int?

  appliesToAllProducts   Boolean  @default(true)
  includedProductIds     Json?
  includedCategoryIds    Json?
  excludedProductIds     Json?
  excludeSaleItems       Boolean  @default(false)

  newCustomersOnly       Boolean  @default(false)

  usageLimitTotal        Int?
  usageLimitPerCustomer  Int?
  usageCount             Int      @default(0)

  allowCombining         Boolean  @default(false)
  freeShipping           Boolean  @default(false)

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  orders                 Order[]
  redemptions            CouponRedemption[]
}

model CouponRedemption {
  id             String   @id @default(uuid())
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Restrict)
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Restrict)
  usedAt         DateTime  @default(now())
  discountAmount Int

  @@index([couponId])
  @@index([customerId])
  @@index([orderId])
}

model Category {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  description    String?
  imageUrl       String?
  parentId       String?
  parent         Category? @relation("CategoryToSubcategories", fields: [parentId], references: [id], onDelete: Restrict)
  subcategories  Category[] @relation("CategoryToSubcategories")

  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  seoTitle       String?
  seoDescription String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products       CategoryProduct[]
  productsMain   Product[] @relation("ProductMainCategory")

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

model CategoryProduct {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([categoryId, productId])
  @@index([categoryId])
  @@index([productId])
}

model Product {
  id                       String    @id @default(uuid())
  title                    String
  slug                     String    @unique
  description              String?
  imageUrl                 String?
  galleryImages            Json?
  basePrice                Int
  salePrice                Int?
  isActive                 Boolean   @default(true)
  isFeatured               Boolean   @default(false)
  allowCustomerImageUpload Boolean   @default(false)
  seoTitle                 String?
  seoDescription           String?
  seoKeywords              String?
  mainCategoryId           String?
  mainCategory             Category? @relation("ProductMainCategory", fields: [mainCategoryId], references: [id], onDelete: SetNull)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  variants    ProductVariant[]
  categories  CategoryProduct[]
  orderItems  OrderItem[]
  homeFeatured HomeFeaturedProduct[]

  @@index([isActive])
  @@index([isFeatured])
  @@index([mainCategoryId])
}

model HomeFeaturedProduct {
  id        String   @id @default(uuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder Int      @default(0)
  badgeText String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model ProductVariant {
  id            String    @id @default(uuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String?   @unique
  color         String?
  pendantType   String?
  material      String?
  priceOverride Int?
  stock         Int       @default(0)
  lowThreshold  Int       @default(5)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]

  @@unique([productId, color, pendantType, material])
  @@index([productId])
  @@index([isActive])
}

model OrderItem {
  id            String          @id @default(uuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  nameSnapshot  String
  unitPrice     Int
  qty           Int
  engravingText String?
  color         String?
  pendantShape  String?
  material      String?
  customerImageUrl String?      @db.Text
  createdAt     DateTime        @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model InventoryLog {
  id        String          @id @default(uuid())
  variantId String
  variant   ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  delta     Int
  reason    InventoryReason
  orderId   String?
  actorId   String?
  note      String?
  createdAt DateTime        @default(now())

  @@index([variantId])
  @@index([orderId])
  @@index([createdAt])
}

// --- Legacy Supabase-managed tables (declared so Prisma db push does NOT drop them).
// These are owned by supabase/schema.sql, not Prisma. Phase A reads from them;
// Phase B+ will phase out reads after verification, then these models + tables
// can be removed safely.
model LegacyProduct {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  slug            String   @unique
  image_url       String?
  price           Int
  is_active       Boolean  @default(true)
  is_customizable Boolean? @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  @@map("products")
}

model LegacySiteSetting {
  id         String   @id @default(uuid()) @db.Uuid
  key        String   @unique
  value      Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@map("site_settings")
}

model AdminUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  fullName     String?
  role         AdminRole  @default(ADMIN)
  isActive     Boolean    @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
