PORT=4000
# CORS_ORIGIN=http://localhost:5173

# Supabase
# SUPABASE_URL="https://<project-ref>.supabase.co"
# SUPABASE_ANON_KEY="sb_publishable_..."
# SUPABASE_SERVICE_ROLE_KEY="(backend only - NEVER expose to frontend)"

# Supabase Postgres connection string (use pooled/non-pooled as needed)
# Example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Grow / Make payments
# Webhook URL in Make that creates a Grow payment link
# GROW_MAKE_CREATE_PAYMENT_LINK_URL="https://hook.eu2.make.com/xxxxxx"
# Optional webhook URL in Make that approves transaction callbacks
# GROW_MAKE_APPROVE_TRANSACTION_URL="https://hook.eu2.make.com/yyyyyy"
# Optional token expected on notify callbacks (x-grow-token header or ?token=)
# GROW_NOTIFY_TOKEN="choose-a-strong-random-token"
# Public base URL used to build notify URL (defaults to request host)
# PUBLIC_APP_BASE_URL="https://your-domain.com"

